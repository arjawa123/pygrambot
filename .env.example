# Pygram - Telegram AI Assistant Configuration

# --- Bot Token ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- Admin Security ---
# Kosongkan untuk mengizinkan semua user, atau pisahkan dengan koma (ID numerik)
ALLOWED_USER_IDS=

# --- Database & Storage ---
BOT_DB_PATH=bot.db
BOT_FILES_DIR=bot_files

# --- LLM Providers ---
# Pilihan: groq
PRIMARY_PROVIDER=groq

# --- Groq ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- OpenRouter (Fallback) ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Gunakan model free sebagai default fallback
OPENROUTER_MODEL_FREE=google/gemini-2.0-flash-lite-preview-02-05:free

# --- Advanced Configuration ---
MAX_HISTORY_MESSAGES=20
MAX_FILE_TEXT_CHARS=12000
MAX_REPLY_CHARS=3500
REQUEST_TIMEOUT=60
ENABLE_CODE_EXECUTION=true
